#include <iostream>
#include <vector>
#include <queue>

using namespace std;

class Rust {
private:
    vector<string> grid;
    int timeInfect[10][10];
    int T;

    int dx[4] = {-1, 0, 1, 0};
    int dy[4] = {0, 1, 0, -1};

    void initializeQueue(queue<pair<int,int>>& q) {
        for (int i = 0; i < 10; i++) {
            for (int j = 0; j < 10; j++) {
                timeInfect[i][j] = -1;

                if (grid[i][j] == '!') {
                    q.push({i, j});
                    timeInfect[i][j] = 0;
                }
            }
        }
    }

    void spreadRust() {
        queue<pair<int,int>> q;
        initializeQueue(q);

        while (!q.empty()) {
            pair<int,int> curr = q.front();
            q.pop();

            int x = curr.first;
            int y = curr.second;

            for (int d = 0; d < 4; d++) {
                int nx = x + dx[d];
                int ny = y + dy[d];

                if (nx >= 0 && nx < 10 && ny >= 0 && ny < 10) {
                    if (grid[nx][ny] == '.' && timeInfect[nx][ny] == -1) {
                        timeInfect[nx][ny] = timeInfect[x][y] + 1;
                        q.push({nx, ny});
                    }
                }
            }
        }
    }

public:
    Rust() {
        grid.resize(10);
    }

    void readInput() {
        for (int i = 0; i < 10; i++) {
            cin >> grid[i];
        }
        cin >> T;
    }

    void process() {
        spreadRust();
    }

    void printResult() {
        for (int i = 0; i < 10; i++) {
            for (int j = 0; j < 10; j++) {
                if (grid[i][j] == '#') {
                    cout << '#';
                }
                else if (timeInfect[i][j] != -1 && timeInfect[i][j] <= T) {
                    cout << '!';
                }
                else {
                    cout << '.';
                }
            }
            cout << endl;
        }
    }
};

int main() {
    Rust rust;

    rust.readInput();
    rust.process();
    rust.printResult();

    return 0;
}
